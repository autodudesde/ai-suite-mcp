    <file source-language="en" datatype="plaintext" original="messages" date="2026-07-13T12:00:00Z" product-name="ai_suite_mcp">
        <header/>
        <body>
            <trans-unit id="aiSuite.mcp.permissions.enableMcpAccess">
                <source>Enable MCP Access</source>
            </trans-unit>

            <trans-unit id="aiSuite.mcp.permissions.enableMcpAccessDescription">
                <source>Allows connecting via MCP protocol (Claude Desktop, Claude.ai, ChatGPT, etc.)</source>
            </trans-unit>

            <trans-unit id="aiSuite.mcp.permissions.enableMcpMediaUpload">
                <source>Enable MCP Media Upload</source>
            </trans-unit>

            <trans-unit id="aiSuite.mcp.permissions.enableMcpMediaUploadDescription">
                <source>Allows uploading images/videos into FAL via MCP (by URL, base64 upload, or YouTube/Vimeo link). Filemount permissions still apply on top.</source>
            </trans-unit>

            <trans-unit id="aiSuite.mcp.permissions.enableMcpRenderedPageRead">
                <source>Enable MCP Rendered Page Read</source>
            </trans-unit>

            <trans-unit id="aiSuite.mcp.permissions.enableMcpRenderedPageReadDescription">
                <source>Allows the readRenderedPage tool. It renders a page through a backend preview session of the MCP user, so it also returns hidden and unpublished pages as well as workspace drafts. The user's own page permissions still apply on top.</source>
            </trans-unit>
        </body>
    </file>
